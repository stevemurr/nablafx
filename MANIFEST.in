# Include documentation and metadata
include README.md
include LICENSE
include UPDATES.md
include INSTALL.md

# Include configuration files
include pyproject.toml

# Include type information
include nablafx/py.typed

# Rational-activations init-weights config (extended version shipped inside the package)
include nablafx/rationals_config.json

# Include configuration examples (optional - users can get from repo)
# recursive-include cfg *.yaml

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
exclude .gitignore
recursive-exclude tests *
recursive-exclude benchmarks *
recursive-exclude scripts *
recursive-exclude docs *
